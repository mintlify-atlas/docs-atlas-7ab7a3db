  "keyFeatures": [
    "Light and dark theme support with runtime switching",
    "GPU-accelerated animated backgrounds using SKSL shaders",
    "Custom color themes with built-in and user-defined palettes",
    "Glassmorphism design system with GlassCard controls",
    "MVVM-friendly Toast and Dialog overlay system",
    "SukiWindow with animated title bar and full-screen support",
    "SukiSideMenu navigation with search and icon support",
    "Animated progress controls: Loading, WaveProgress, CircleProgressBar, Stepper",
    "Complete set of styled input controls (Button, TextBox, ComboBox, etc.)",
    "PropertyGrid and SettingsLayout for structured settings UIs"
  ],
